# Monorepo root gitignore
# Each subproject (app/, site/) has its own .gitignore

# Dependencies
node_modules/

# Environment variables
.env
.env.local
.env.production
.env.*.local

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Build outputs
dist/
.next/
out/

# Misc
*.tgz
.turbo

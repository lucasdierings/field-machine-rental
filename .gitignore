# Monorepo root gitignore
# Each subproject (app/, site/) has its own .gitignore

# OS
.DS_Store
Thumbs.db

# IDE
.vscode/*
!.vscode/extensions.json
.idea

# Dependencies
node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# Mobile native projects (generated by Capacitor)
mobile/android/
mobile/ios/
mobile/.capacitor/

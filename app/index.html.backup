<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <!-- SEO Meta Tags -->
    <title>FieldMachine - Aluguel de Máquinas Agrícolas no Paraná | Tratores, Colheitadeiras</title>
    <meta name="description" content="Alugue tratores, colheitadeiras e máquinas agrícolas no Paraná. ✓ Proprietários verificados ✓ Seguro incluído ✓ Economize 40%. Cadastre-se grátis!">
    <meta name="keywords" content="aluguel máquinas agrícolas, trator aluguel Paraná, colheitadeira aluguel, pulverizador aluguel, FieldMachine">
    <meta name="author" content="FieldMachine" />
    <link rel="canonical" href="https://fieldmachine.com.br" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://fieldmachine.com.br" />
    <meta property="og:title" content="FieldMachine - Aluguel de Máquinas Agrícolas no Paraná" />
    <meta property="og:description" content="Alugue tratores, colheitadeiras e máquinas agrícolas no Paraná. ✓ Proprietários verificados ✓ Seguro incluído ✓ Economize 40%." />
    <meta property="og:image" content="/og-image-field-machine.jpg" />
    <meta property="og:locale" content="pt_BR" />
    <meta property="og:site_name" content="FieldMachine" />
    
    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content="https://fieldmachine.com.br" />
    <meta property="twitter:title" content="FieldMachine - Aluguel de Máquinas Agrícolas no Paraná" />
    <meta property="twitter:description" content="Alugue tratores, colheitadeiras e máquinas agrícolas no Paraná. ✓ Proprietários verificados ✓ Seguro incluído ✓ Economize 40%." />
    <meta property="twitter:image" content="/og-image-field-machine.jpg" />
    
    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": "FieldMachine",
      "url": "https://fieldmachine.com.br",
      "logo": "https://fieldmachine.com.br/logo.png",
      "description": "Plataforma de aluguel de máquinas agrícolas no Paraná",
      "address": {
        "@type": "PostalAddress",
        "addressRegion": "Paraná",
        "addressCountry": "BR"
      },
      "sameAs": [
        "https://facebook.com/fieldmachine",
        "https://instagram.com/fieldmachine"
      ]
    }
    </script>
    <link rel="icon" type="image/x-icon" href="https://storage.googleapis.com/gpt-engineer-file-uploads/6PC57Dxx3SYtKG8ycblXeDnI1Mf1/uploads/1757780505248-ChatGPT Image 13 de set. de 2025, 13_20_55.png">
</head>

  <body>
    <div id="root"></div>

    <!-- Mobile Debug Overlay (only visible on errors) -->
    <div id="mobile-debug" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:rgba(0,0,0,0.95); color:#fff; padding:20px; overflow-y:auto; z-index:999999; font-family:monospace; font-size:12px;">
      <h2 style="color:#ef4444; margin-bottom:20px;">⚠️ Erro Detectado</h2>
      <div id="debug-logs"></div>
      <button onclick="document.getElementById('mobile-debug').style.display='none'" style="position:fixed; top:10px; right:10px; padding:10px 20px; background:#10b981; color:white; border:none; border-radius:4px;">Fechar</button>
    </div>

    <!-- Emergency Mode (shown if app fails to load after 10s) -->
    <div id="emergency-mode" style="display:none; position:fixed; top:0; left:0; right:0; bottom:0; background:#ffffff; color:#000; padding:30px; overflow-y:auto; z-index:999998; font-family:-apple-system, sans-serif;">
      <div style="max-width:500px; margin:0 auto;">
        <h1 style="color:#ef4444; font-size:28px; margin-bottom:20px; text-align:center;">🚨 Modo de Emergência</h1>
        <p style="font-size:16px; color:#666; margin-bottom:30px; text-align:center;">O aplicativo não conseguiu carregar corretamente.</p>

        <div style="background:#f3f4f6; padding:20px; border-radius:8px; margin-bottom:20px;">
          <h3 style="font-size:18px; margin-bottom:15px; color:#374151;">Possíveis causas:</h3>
          <ul style="margin-left:20px; color:#6b7280; line-height:1.8;">
            <li>Conexão com internet instável</li>
            <li>Servidor Supabase não respondendo</li>
            <li>Erro no carregamento dos componentes</li>
            <li>Problema de compatibilidade do navegador</li>
          </ul>
        </div>

        <div style="display:flex; flex-direction:column; gap:12px;">
          <button onclick="window.location.reload()" style="width:100%; padding:16px; background:#16a34a; color:#fff; border:none; border-radius:8px; font-size:16px; font-weight:600; cursor:pointer;">
            🔄 Recarregar App
          </button>
          <button onclick="localStorage.clear(); window.location.reload()" style="width:100%; padding:16px; background:#3b82f6; color:#fff; border:none; border-radius:8px; font-size:16px; font-weight:600; cursor:pointer;">
            🧹 Limpar Cache e Recarregar
          </button>
          <button onclick="document.getElementById('emergency-mode').style.display='none'; document.getElementById('mobile-debug').style.display='block'" style="width:100%; padding:16px; background:#6b7280; color:#fff; border:none; border-radius:8px; font-size:16px; font-weight:600; cursor:pointer;">
            🐛 Ver Logs de Debug
          </button>
        </div>

        <p style="margin-top:30px; font-size:12px; color:#9ca3af; text-align:center;">
          Se o problema persistir, entre em contato com o suporte técnico.
        </p>
      </div>
    </div>

    <script>
      // Mobile error capture for iOS debugging
      (function() {
        const debugDiv = document.getElementById('mobile-debug');
        const logsDiv = document.getElementById('debug-logs');
        let hasError = false;

        function showError(message, type = 'error') {
          hasError = true;
          const entry = document.createElement('div');
          entry.style.cssText = 'padding:10px; margin:5px 0; background:' + (type === 'error' ? '#ef4444' : '#3b82f6') + '; border-radius:4px; font-size:11px;';
          entry.textContent = new Date().toLocaleTimeString() + ' - ' + message;
          logsDiv.appendChild(entry);
          debugDiv.style.display = 'block';
        }

        // Check environment
        try {
          // Test localStorage
          try {
            localStorage.setItem('__test', '1');
            localStorage.removeItem('__test');
            showError('✓ localStorage OK', 'info');
          } catch (e) {
            showError('✗ localStorage FALHOU: ' + e.message);
          }

          // Check Capacitor
          if (window.Capacitor) {
            showError('✓ Capacitor detectado: v' + window.Capacitor.getPlatform(), 'info');
          } else {
            showError('✗ Capacitor NÃO detectado', 'error');
          }
        } catch (e) {
          showError('Erro na inicialização: ' + e.message);
        }

        // Capture uncaught errors
        window.addEventListener('error', (e) => {
          showError('ERROR: ' + e.message + ' at ' + e.filename + ':' + e.lineno);
        });

        // Capture promise rejections
        window.addEventListener('unhandledrejection', (e) => {
          showError('PROMISE ERROR: ' + (e.reason?.message || e.reason));
        });

        // Check if React mounted after 7 seconds (mais tempo para Suspense)
        setTimeout(() => {
          const root = document.getElementById('root');

          // Verificar se há algum conteúdo renderizado
          if (!root || root.children.length === 0) {
            showError('✗ React não renderizou - #root vazio!');
            showError('Possível: Suspense travado ou ErrorBoundary ativo', 'error');
          } else {
            // Verificar se é só o loader ou se tem conteúdo real
            const hasRealContent = root.textContent && root.textContent.length > 20;

            if (!hasRealContent && !hasError) {
              showError('⚠️ Suspense pode estar travado - apenas loader visível', 'error');
            } else if (!hasError) {
              showError('✓ React renderizado OK!', 'info');
              // Auto-hide after 3 seconds if no errors
              setTimeout(() => {
                debugDiv.style.display = 'none';
              }, 3000);
            }
          }
        }, 7000);

        // Emergency mode: se após 10s ainda não renderizou, mostrar tela de emergência
        setTimeout(() => {
          const root = document.getElementById('root');
          const hasContent = root && root.children.length > 0 && root.textContent && root.textContent.length > 20;

          if (!hasContent) {
            showError('⚠️ ATIVANDO MODO DE EMERGÊNCIA', 'error');
            setTimeout(() => {
              document.getElementById('emergency-mode').style.display = 'block';
            }, 1000);
          }
        }, 10000);
      })();
    </script>

    <script type="module" src="/src/main.tsx"></script>
  </body>
</html>
